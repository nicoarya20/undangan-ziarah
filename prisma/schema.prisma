generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Invitation {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  eventDate       DateTime
  locationName    String
  locationAddress String
  googleMapsUrl   String?
  musicUrl        String?
  theme           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deceased        String
  organizer       String?
  guests          Guest[]
  messages        Message[]
}

model Guest {
  id           String     @id @default(uuid())
  invitationId String
  name         String
  slug         String
  createdAt    DateTime   @default(now())
  invitation   Invitation @relation(fields: [invitationId], references: [id])
  messages     Message[]
  rsvp         RSVP?
}

model RSVP {
  id         String     @id @default(uuid())
  guestId    String     @unique
  status     RSVPStatus @default(UNCERTAIN)
  guestCount Int        @default(1)
  createdAt  DateTime   @default(now())
  guest      Guest      @relation(fields: [guestId], references: [id])
}

model Message {
  id           String     @id @default(uuid())
  invitationId String
  guestId      String?
  name         String?
  content      String
  createdAt    DateTime   @default(now())
  guest        Guest?     @relation(fields: [guestId], references: [id])
  invitation   Invitation @relation(fields: [invitationId], references: [id])
}

enum RSVPStatus {
  ATTENDING
  NOT_ATTENDING
  UNCERTAIN
}
